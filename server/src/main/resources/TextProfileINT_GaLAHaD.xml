<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ComponentSpec xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" isProfile="true" CMDVersion="1.2"
               CMDOriginalVersion="1.2"
               xsi:noNamespaceSchemaLocation="https://infra.clarin.eu/CMDI/1.x/xsd/cmd-component.xsd">
    <Header>
        <ID>clarin.eu:cr1:p_1733830015142</ID>
        <Name>TextProfileINT_GaLAHaD_v4</Name>
        <Description>A profile which describes a file processed by the GaLAHaD platform
            (https://portal.clarin.ivdnt.org/galahad/home)
        </Description>
        <Status>development</Status>
        <DerivedFrom>clarin.eu:cr1:p_1712653174452</DerivedFrom>
    </Header>
    <Component name="TextProfileINT_GaLAHaD_v4" CardinalityMin="1" CardinalityMax="1">
        <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1" name="corpusName" ValueScheme="string" CardinalityMin="0"
                 CardinalityMax="1"
                 cue:DisplayPriority="1"/>
        <Component name="TextFile_GaLAHaD" ComponentRef="clarin.eu:cr1:c_1712653174437" CardinalityMin="1"
                   CardinalityMax="1">
            <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1"
                     name="GaLAHaDPersistentIdentifier"
                     ConceptLink="http://hdl.handle.net/11459/CCR_C-2573_ae7c2548-8a86-ab6e-7099-e28b7697d1a2"
                     ValueScheme="string" CardinalityMin="1" CardinalityMax="1"
                     cue:DisplayPriority="1">
                <Documentation>A persistent identifier for a text. The pid is given by the GaLAHaD platform.
                </Documentation>
            </Element>
            <Component name="Conversion_GaLAHaD" ComponentRef="clarin.eu:cr1:c_1712653174444" CardinalityMin="1"
                       CardinalityMax="1">
                <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1" name="conversionDescription" ValueScheme="string"
                         CardinalityMin="1"
                         CardinalityMax="1" cue:DisplayPriority="1">
                    <Documentation>Describes the conversion process</Documentation>
                </Element>
                <Component name="Tool" ComponentRef="clarin.eu:cr1:c_1708423613597" CardinalityMin="1"
                           CardinalityMax="1">
                    <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1" name="toolName" ValueScheme="string"
                             CardinalityMin="1"
                             CardinalityMax="1" cue:DisplayPriority="1">
                        <Documentation>Name of a tool</Documentation>
                    </Element>
                    <Element name="toolVersion" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                        <Documentation>Identifier of the version of a tool, e.g. a date, a version number,...
                        </Documentation>
                    </Element>
                    <Element name="toolURL" ValueScheme="string" CardinalityMin="0" CardinalityMax="unbounded">
                        <Documentation>Locates a tool by means of a URL</Documentation>
                    </Element>
                </Component>
                <Component name="Organisation" ComponentRef="clarin.eu:cr1:c_1712653174406" CardinalityMin="1"
                           CardinalityMax="1">
                    <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1"
                             name="organisationName"
                             ConceptLink="http://hdl.handle.net/11459/CCR_C-6243_bd27ac08-ec04-0db2-d95c-52f2a6b1e59d"
                             ValueScheme="string" CardinalityMin="1" CardinalityMax="1"
                             cue:DisplayPriority="1"/>
                    <Element name="organisationURL" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                        <Documentation>Locates the website of an organisation by means of a URL</Documentation>
                    </Element>
                </Component>
            </Component>
        </Component>
        <Component name="Source_GaLAHaD" ComponentRef="clarin.eu:cr1:c_1712653174438" CardinalityMin="1"
                   CardinalityMax="1">
            <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1" name="sourceID" ValueScheme="string" CardinalityMin="0"
                     CardinalityMax="1"
                     cue:DisplayPriority="1">
                <Documentation>The ID of the original text</Documentation>
            </Element>
            <Element name="sourceCollection" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                <Documentation>Name of the collection where the text originates from</Documentation>
            </Element>
            <Element name="sourceCollectionURI" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                <Documentation>The online location of the source collection</Documentation>
            </Element>
            <Component name="Date_Period" ComponentRef="clarin.eu:cr1:c_1527668176057" CardinalityMin="0"
                       CardinalityMax="1">
                <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1" name="yearFrom" ValueScheme="gYear"
                         CardinalityMin="0"
                         CardinalityMax="1" cue:DisplayPriority="1">
                    <Documentation>Start year of a range of years</Documentation>
                </Element>
                <Element name="yearTo" ValueScheme="gYear" CardinalityMin="0" CardinalityMax="1">
                    <Documentation>End year of a range of years</Documentation>
                </Element>
                <Element name="monthFrom" ValueScheme="gMonth" CardinalityMin="0" CardinalityMax="1">
                    <Documentation>Start month of a range of months</Documentation>
                </Element>
                <Element name="monthTo" ValueScheme="gMonth" CardinalityMin="0" CardinalityMax="1">
                    <Documentation>End month of a range of months</Documentation>
                </Element>
                <Element name="dayFrom" ValueScheme="gDay" CardinalityMin="0" CardinalityMax="1">
                    <Documentation>Start day of a range of days</Documentation>
                </Element>
                <Element name="dayTo" ValueScheme="gDay" CardinalityMin="0" CardinalityMax="1">
                    <Documentation>End day of a range of days</Documentation>
                </Element>
            </Component>
        </Component>
        <Component name="Language_GaLAHaD" ComponentRef="clarin.eu:cr1:c_1712653174441" CardinalityMin="1"
                   CardinalityMax="1">
            <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1" name="languageName" ValueScheme="string"
                     CardinalityMin="1"
                     CardinalityMax="1" cue:DisplayPriority="1"/>
            <Element name="dominantLanguage" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                <Documentation>Indicates whether the language is the dominant one. The possible values for this element
                    are "true", "false" and "unspecified".
                </Documentation>
            </Element>
        </Component>
        <Component name="Annotation_GaLAHaD" ComponentRef="clarin.eu:cr1:c_1712653174453" CardinalityMin="1"
                   CardinalityMax="1">
            <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1"
                     name="annotationType"
                     ConceptLink="http://hdl.handle.net/11459/CCR_C-2462_5b266792-7a54-9296-42e2-2318b9861fe1"
                     CardinalityMin="1" CardinalityMax="1"
                     cue:DisplayPriority="1">
                <Documentation>Specifies the type of annotation that was provided</Documentation>
                <ValueScheme>
                    <Vocabulary>
                        <enumeration>
                            <item>Lemmatisation and POS-tagging</item>
                        </enumeration>
                    </Vocabulary>
                </ValueScheme>
            </Element>
            <Element name="annotationStyle"
                     ConceptLink="http://hdl.handle.net/11459/CCR_C-2507_94b29b04-98e8-fca3-a0ef-3a44d795b0da"
                     CardinalityMin="0" CardinalityMax="1">
                <Documentation>Specifies whether the annotation is created inline, stand-off or a combination of both
                    styles.
                </Documentation>
                <ValueScheme>
                    <Vocabulary>
                        <enumeration>
                            <item>inline</item>
                        </enumeration>
                    </Vocabulary>
                </ValueScheme>
            </Element>
            <Element name="annotationDocumentation" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                <Documentation>Identifies the documentation of an annotation by means of a URI</Documentation>
            </Element>
            <Element name="annotationSet"
                     ConceptLink="http://hdl.handle.net/11459/CCR_C-2497_6e93b9ce-1be7-248f-ab63-ba0b9c63661f"
                     ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                <Documentation>Identifies the tagset of an annotation. e.g. by means of a URI or by means of a name
                </Documentation>
            </Element>
            <Component name="Provenance" CardinalityMin="0" CardinalityMax="1">
                <Documentation>Provides information about the creation of an annotation</Documentation>
                <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1"
                         name="annotationFormat"
                         ConceptLink="http://hdl.handle.net/11459/CCR_C-2562_872eb94a-47fb-b551-2f64-13ded063259e"
                         ValueScheme="string" CardinalityMin="0" CardinalityMax="1"
                         cue:DisplayPriority="1">
                    <Documentation>Specifies the annotation format</Documentation>
                </Element>
                <Element name="annotationDescription" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                    <Documentation>Description in general prose of the annotation process</Documentation>
                </Element>
                <Component name="AnnotationProcess" CardinalityMin="0" CardinalityMax="unbounded">
                    <Documentation>Identifies the annotationMode and the person(s), organisation(s) and/or tool(s)
                        involved
                    </Documentation>
                    <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1" name="annotationMode" CardinalityMin="0"
                             CardinalityMax="1"
                             cue:DisplayPriority="1">
                        <Documentation>Indicates whether the resource is annotated manually, by automatic processes or
                            by a combination of both
                        </Documentation>
                        <ValueScheme>
                            <Vocabulary>
                                <enumeration>
                                    <item>automatically annotated</item>
                                    <item>manually verified</item>
                                </enumeration>
                            </Vocabulary>
                        </ValueScheme>
                    </Element>
                    <Component name="ProcessorsAnnotators" CardinalityMin="0" CardinalityMax="1">
                        <Documentation>Groups persons, organisations and/or tools involved in the annotation process
                        </Documentation>
                        <Component name="Person_GaLAHaD" ComponentRef="clarin.eu:cr1:c_1712653174451" CardinalityMin="0"
                                   CardinalityMax="unbounded">
                            <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1" name="email" ValueScheme="string"
                                     CardinalityMin="0"
                                     CardinalityMax="1" cue:DisplayPriority="1">
                                <Documentation>Specifies the email address of the user</Documentation>
                            </Element>
                        </Component>
                        <Component name="Organisation" ComponentRef="clarin.eu:cr1:c_1712653174406" CardinalityMin="0"
                                   CardinalityMax="unbounded">
                            <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1"
                                     name="organisationName"
                                     ConceptLink="http://hdl.handle.net/11459/CCR_C-6243_bd27ac08-ec04-0db2-d95c-52f2a6b1e59d"
                                     ValueScheme="string" CardinalityMin="1" CardinalityMax="1"
                                     cue:DisplayPriority="1"/>
                            <Element name="organisationURL" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                                <Documentation>Locates the website of an organisation by means of a URL</Documentation>
                            </Element>
                        </Component>
                        <Component name="Tool" ComponentRef="clarin.eu:cr1:c_1708423613597" CardinalityMin="0"
                                   CardinalityMax="unbounded">
                            <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1" name="toolName" ValueScheme="string"
                                     CardinalityMin="1"
                                     CardinalityMax="1" cue:DisplayPriority="1">
                                <Documentation>Name of a tool</Documentation>
                            </Element>
                            <Element name="toolVersion" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                                <Documentation>Identifier of the version of a tool, e.g. a date, a version number,...
                                </Documentation>
                            </Element>
                            <Element name="toolURL" ValueScheme="string" CardinalityMin="0" CardinalityMax="unbounded">
                                <Documentation>Locates a tool by means of a URL</Documentation>
                            </Element>
                        </Component>
                    </Component>
                    <Component name="Date_Period" ComponentRef="clarin.eu:cr1:c_1527668176057" CardinalityMin="0"
                               CardinalityMax="1">
                        <Element xmlns:cue="http://www.clarin.eu/cmd/cues/1" name="yearFrom" ValueScheme="gYear"
                                 CardinalityMin="0"
                                 CardinalityMax="1" cue:DisplayPriority="1">
                            <Documentation>Start year of a range of years</Documentation>
                        </Element>
                        <Element name="yearTo" ValueScheme="gYear" CardinalityMin="0" CardinalityMax="1">
                            <Documentation>End year of a range of years</Documentation>
                        </Element>
                        <Element name="monthFrom" ValueScheme="gMonth" CardinalityMin="0" CardinalityMax="1">
                            <Documentation>Start month of a range of months</Documentation>
                        </Element>
                        <Element name="monthTo" ValueScheme="gMonth" CardinalityMin="0" CardinalityMax="1">
                            <Documentation>End month of a range of months</Documentation>
                        </Element>
                        <Element name="dayFrom" ValueScheme="gDay" CardinalityMin="0" CardinalityMax="1">
                            <Documentation>Start day of a range of days</Documentation>
                        </Element>
                        <Element name="dayTo" ValueScheme="gDay" CardinalityMin="0" CardinalityMax="1">
                            <Documentation>End day of a range of days</Documentation>
                        </Element>
                    </Component>
                </Component>
            </Component>
        </Component>
    </Component>
</ComponentSpec>
